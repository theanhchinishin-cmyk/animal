<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trò Chơi: Con Vật Bí Ẩn</title>
    <link rel="stylesheet" href="/style/home.css" />
    <link rel="stylesheet" href="/style/secret.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Comfortaa:wght@700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>

  <body class="secret-game-page">
    <%- include('partials/header') %>

    <div class="game-container">
      <header class="game-internal-header">
        <div class="score-board">🌟 <span id="sticker-count">0</span></div>
        <h1>🕵️‍♂️ CON VẬT BÍ ẨN 🕵️‍♀️</h1>
        <p class="sub-title">Bé hãy đọc gợi ý và đoán tên con vật nhé!</p>
      </header>

      <div class="card question-card">
        <div class="badge">
          CÂU HỎI <span id="current-round">1</span>/<span id="total-rounds"
            >6</span
          >
        </div>
        <div class="teacher-speech">
          <p id="clue-text">Đang tải câu đố cho bé...</p>
        </div>
      </div>

      <div class="interaction-area">
        <input
          type="text"
          id="answer-input"
          placeholder="Bé gõ câu trả lời vào đây..."
          autocomplete="off"
        />
        <button id="guess-btn">ĐOÁN XEM! 🚀</button>
      </div>

      <div id="result-card" class="card result-card hidden">
        <div class="victory-banner">🎉 CHÍNH XÁC RỒI! 🎉</div>
        <div class="sticker-reward">Bạn được thưởng 1 sticker: 🌟</div>
        <div class="animal-image-box">
          <img id="animal-img" src="" alt="Đáp án" />
        </div>
        <h2 id="animal-name">CON CHÓ</h2>
        <button id="next-btn">CÂU TIẾP THEO ➡️</button>
      </div>
    </div>

    <div id="finish-modal" class="modal">
      <div class="modal-content">
        <h2>👑 BÉ THẬT LÀ SIÊU! 👑</h2>
        <p>
          Bé đã xuất sắc giải được hết các câu đố của cô và thu thập đủ 3
          sticker 🌟 rồi!
        </p>
        <div class="final-stickers">🌟 🌟 🌟</div>
        <button id="restart-btn">Chơi lại từ đầu nha</button>
      </div>
    </div>

    <script src="/js/secret.js"></script>
    <script src="/js/home.js"></script>
  </body>
</html>
