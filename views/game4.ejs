<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>📦 Game 4: Xếp Con Vật Theo Lợi Ích</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style/home.css" />
    <link rel="stylesheet" href="/style/style.css" />
    <link rel="stylesheet" href="/style/game4.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>

  <body class="game4-page">
    <%- include('partials/header') %>

    <div class="main-container">
      <header>
        <div class="score-board">⭐ <span id="score-count">0</span>/<span id="total-items">10</span></div>
        <h1>📦 Xếp Con Vật Theo Lợi Ích</h1>
        <p class="sub-title">Kéo thả các con vật vào đúng ô lợi ích nhé!</p>
      </header>

      <div class="drag-instruction">
        👆 Kéo con vật phía dưới thả vào ô tương ứng
      </div>

      <div class="section-label">🐾 Các con vật</div>
      <div class="draggable-area" id="draggable-area"></div>

      <div class="section-label">🎯 Lợi ích</div>
      <div class="drop-zones" id="drop-zones"></div>

      <div class="feedback hidden" id="feedback"></div>

      <button class="reset-btn" id="reset-btn">🔄 Chơi lại</button>
    </div>

    <div class="victory-modal" id="victory-modal">
      <div class="modal-content">
        <h2>🎉 Con thật giỏi! 🎉</h2>
        <p>Con đã xếp đúng tất cả các con vật vào đúng lợi ích!</p>
        <button class="restart-btn" id="restart-btn">Chơi lại từ đầu</button>
      </div>
    </div>

    <script src="/js/game4.js"></script>
  </body>
</html>
