<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>🤔 Game 3: Đố Bạn Con Gì?</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style/home.css" />
    <link rel="stylesheet" href="/style/style.css" />
    <link rel="stylesheet" href="/style/game3.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>

  <body class="game3-page">
    <%- include('partials/header') %>

    <div class="main-container">
      <header>
        <div class="score-board">⭐ <span id="score-count">0</span></div>
        <h1>🤔 Đố Bạn Con Gì?</h1>
        <p class="sub-title">Con hãy đọc câu đố và đoán tên con vật nhé!</p>
      </header>

      <div class="progress-section">
        <span class="progress-text">Câu <span id="current-q">1</span>/<span id="total-q">3</span></span>
        <div class="progress-dots" id="progress-dots"></div>
      </div>

      <div class="question-card">
        <div class="badge">CÂU ĐỐ</div>
        <p class="riddle-text" id="riddle-text">Đang tải câu đố...</p>
      </div>

      <div class="interaction-area">
        <input
          type="text"
          id="answer-input"
          placeholder="Con gõ câu trả lời vào đây..."
          autocomplete="off"
        />
        <button id="guess-btn">Đoán! 🚀</button>
      </div>

      <div class="feedback hidden" id="feedback"></div>

      <div class="result-card hidden" id="result-card">
        <div class="victory-banner">🎉 Chính xác! 🎉</div>
        <div class="sticker-reward">+1 điểm</div>
        <span class="result-emoji" id="result-emoji">🦀</span>
        <div class="result-animal-name" id="result-name">Con Cua</div>
        <button id="next-btn">Câu tiếp theo ➡️</button>
      </div>
    </div>

    <div class="victory-modal" id="victory-modal">
      <div class="modal-content">
        <h2>👑 Con thật là siêu! 👑</h2>
        <p>Con đã giải được tất cả các câu đố!</p>
        <button class="restart-btn" id="restart-btn">Chơi lại từ đầu</button>
      </div>
    </div>

    <script src="/js/game3.js"></script>
  </body>
</html>
