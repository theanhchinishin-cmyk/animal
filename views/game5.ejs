<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>⚠️ Game 5: Con Vật Gây Hại Gì?</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style/home.css" />
    <link rel="stylesheet" href="/style/style.css" />
    <link rel="stylesheet" href="/style/game5.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>

  <body class="game5-page">
    <%- include('partials/header') %>

    <div class="main-container">
      <header>
        <div class="score-board">⭐ <span id="score-count">0</span></div>
        <h1>⚠️ Con Vật Gây Hại Gì?</h1>
        <p class="sub-title">Con hãy chọn tác hại đúng của con vật nhé!</p>
      </header>

      <div class="progress-section">
        <span class="progress-text">Câu <span id="current-q">1</span>/<span id="total-q">4</span></span>
        <div class="progress-dots" id="progress-dots"></div>
      </div>

      <div class="animal-display">
        <img class="animal-emoji" id="animal-emoji" src="/images/mouse.jpg" alt="Con vật" style="width:220px;height:220px;object-fit:cover;border-radius:24px;">
        <div class="animal-name" id="animal-name">Con Chuột</div>
      </div>

      <div class="question-text">Con vật này gây tác hại gì?</div>

      <div class="options-grid" id="options-grid"></div>

      <div class="feedback hidden" id="feedback"></div>

      <button class="next-btn hidden" id="next-btn">Câu tiếp theo ➡️</button>
    </div>

    <div class="victory-modal" id="victory-modal">
      <div class="modal-content">
        <h2>🎉 Hoàn thành xuất sắc! 🎉</h2>
        <p>Con đã biết tác hại của các con vật có hại!</p>
        <button class="restart-btn" id="restart-btn">Chơi lại từ đầu</button>
      </div>
    </div>

    <script src="/js/game5.js"></script>
  </body>
</html>
